# ============================================================
# CheckInHelper 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================================

# ---- 数据库 ----
# MySQL 连接串
DATABASE_URL=mysql+pymysql://checkinhelper:你的密码@localhost:3306/checkinhelper?charset=utf8mb4

# Redis 连接串（支持认证：redis://:密码@host:port/db 或 redis://用户:密码@host:port/db）
REDIS_URL=redis://localhost:6379/0

# SQL 日志（开发调试用，生产设为 false）
DB_ECHO=false

# 数据库连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# 启动时自动同步数据库结构（SchemaSync — 自动检测模型差异、备份、执行 DDL、审计日志）
# 参见 app/core/schema_sync.py
DB_AUTO_MIGRATE=true

# 数据库备份目录（SchemaSync 在破坏性 DDL 前自动备份受影响表）
# DB_BACKUP_DIR=./backups

# 备份保留天数（超过此天数的旧备份目录自动清理，0 表示不清理）
# DB_BACKUP_RETENTION_DAYS=30

# ---- JWT 认证 ----
# 生产环境务必设置为强随机字符串
JWT_SECRET=请替换为随机生成的密钥

# JWT 算法（默认 HS256，仅允许 HS*/RS*/ES*）
# JWT_ALGORITHM=HS256

# Token 有效期（小时，默认 24）
# JWT_EXPIRE_HOURS=24

# ---- 凭据加密 ----
# 课堂派账号密码加密密钥。
# 生成方式：uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# CREDENTIAL_KEY=

# ---- CORS ----
# 允许的跨域来源，逗号分隔，留空则禁止跨域
# 示例：http://localhost:8765,https://your-domain.com
ALLOWED_ORIGINS=http://localhost:8765

# ---- 服务 ----
# 监听端口（默认 8765）
PORT=8765

# 调试模式（生产环境设为 False）
DEBUG=False
